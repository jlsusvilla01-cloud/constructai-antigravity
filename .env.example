# Supabase (get from supabase.com → Project Settings → API)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# PayMongo (get from dashboard.paymongo.com → Developers → API Keys)
PAYMONGO_SECRET_KEY=sk_test_xxx
PAYMONGO_WEBHOOK_SECRET=whsec_xxx

# App URL (your Vercel deployment URL or custom domain)
APP_URL=https://constructai.ph

# ─── Frontend (embedded directly in index.html) ───────────────────────────────
# These are PUBLIC keys — safe to expose in browser code.
# Replace the placeholder values in index.html:
#   SUPABASE_URL       → your project URL above
#   SUPABASE_ANON_KEY  → from supabase.com → Project Settings → API → anon public
